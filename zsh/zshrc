# Path
export PATH="$PATH:$HOME/.local/bin:$HOME/.composer/vendor/bin:$HOME/.spicetify:$HOME/.pyenv/bin:$HOME/.bun/bin:$HOME/.local/share/JetBrains/Toolbox/scripts:"

# Path to OMZ installation.
export ZSH="$HOME/.oh-my-zsh"

# Editor env variables
export EDITOR=vim
export SUDO_EDITOR=vim

# Theme
ZSH_THEME="refined"

# Plugins
plugins=(cp fast-syntax-highlighting fzf git poetry zsh-autosuggestions)

# OMZ script
source $ZSH/oh-my-zsh.sh

# Aliases
alias ls="eza --color=always --icons --group-directories-first"
alias la="eza -lah --color=always --icons --group-directories-first"
alias lt="eza -aT --color=always --icons --group-directories-first"
alias lh="eza -la --color=always --icons --group-directories-first | grep '^\.'"
alias ga="git add -A"
alias gs="git status"
alias gc="git commit -m"
alias cp="cpv"
alias ar="php artisan"
alias rm="trash"
alias c="clear"
alias fzf="fzf --style full"
alias dir="cd ~ && cd \$(find * -type d | fzf)"
alias ff="fastfetch"

# Zypper
alias zse="zypper se -s"
alias zpa="zypper pa"
alias zls="sudo zypper ls"
alias zin="sudo zypper in"
alias zinr="sudo zypper inr"
alias zrm="sudo zypper rm"
alias zsi="sudo zypper si"
alias zve="sudo zypper ve"
alias zref="sudo zypper ref"
alias zup="sudo zypper up"
alias zdup="sudo zypper dup"
alias zar="sudo zypper ar"
alias zrr="sudo zypper rr"

# GPG stuff
export GPG_TTY=$(tty)

# bun completions
[ -s "/home/aileks/.bun/_bun" ] && source "/home/aileks/.bun/_bun"

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"
export PIPENV_VENV_IN_PROJECT=1

# Zoxide
eval "$(zoxide init zsh)"

# fzf plugin config
export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"
export FZF_ALT_C_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'tree -C {}'"

# nvm
export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
