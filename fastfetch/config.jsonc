            "detectionMethod": "pci",
            "key": "  оүҰ"
        },
        {
            "type": "display",
            "key": "  уұ„„"
        },
        {
            "type": "memory",
            "key": "  оҝ…"
        },
        {
            "type": "custom", // SoftwareStart
            "format": "в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ \u001b[1mSoftware Information\u001b[0m в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө"
        },
        {
            "type": "os",
            "key": "  оҪҶ"
