
# Variables
set $mod Mod4
set $term wezterm
set $browser vivaldi
set $fm thunar
set $menu rofi -show drun

# Set Font
font pango:Rubik 14

# Color Palette
set $base           #191724
set $surface        #1f1d2e
set $overlay        #26233a
set $muted          #6e6a86
set $subtle         #908caa
set $text           #e0def4
set $love           #eb6f92
set $gold           #f6c177
set $rose           #ebbcba
set $pine           #31748f
set $foam           #9ccfd8
set $iris           #c4a7e7
set $highlightlow   #21202e
set $highlightmed   #403d52
set $highlighthigh  #524f67

# Applications
bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+space exec $menu
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+w exec $browser
bindsym $mod+e exec $fm
bindsym $mod+d exec discord
bindsym $mod+Shift+x exec i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'
bindsym Print exec --no-startup-id maim -s | xclip -selection clipboard -t image/png
bindsym $mod+Print exec --no-startup-id maim ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%M-%S).png
bindsym $mod+Shift+n exec --no-startup-id dunstctl close-all

# Window Navigation
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Window Resizing
bindsym $mod+Control+h resize shrink width 20 px
bindsym $mod+Control+l resize grow width 20 px
bindsym $mod+Control+k resize shrink height 20 px
bindsym $mod+Control+j resize grow height 20 px

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"

# Workspace Navigation
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7

# Layout Management
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+a focus parent
bindsym $mod+Shift+space floating toggle
floating_modifier $mod

# Bar
bar {
    status_command i3status
    position top
    colors {
        background $rose_pine_base
        statusline $rose_pine_text
        separator  $rose_pine_subtle

        # class             border              background         text
        focused_workspace   $foam               $surface           $text
        active_workspace    $overlay            $muted             $text
        inactive_workspace  $surface            $base              $text
        urgent_workspace    $love               $love              $text
    }
}


# Borders
default_border pixel 1
default_floating_border pixel 1
client.focused           $rose     $base $text  $rose      $rose
client.focused_inactive  $text     $base $text  $subtle    $surface
client.unfocused         $text     $base $text  $overlay   $overlay
client.urgent            $text     $base $text  $love      $love
client.placeholder       $base     $base $text  $overlay   $overlay
client.background        $base

# Gaps
gaps inner 4
gaps outer 4

# Window Rules
for_window [class="Galculator"] floating enable
for_window [class="Blueman-manager"] floating enable
for_window [window_type="dialog"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_type="utility"] floating enable
for_window [title="File Operation Progress"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="nm-connection-editor"] floating enable

# Screen Locking
set $lock i3lock -c 191724
bindsym $mod+escape exec $lock
exec --no-startup-id xss-lock --transfer-sleep-lock -- $lock

# Media Keys
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous

# Autostart
exec --no-startup-id /usr/lib/xfce-polkit/xfce-polkit
exec --no-startup-id nm-applet
exec --no-startup-id dunst
exec_always --no-startup-id picom -b
exec_always --no-startup-id feh --bg-fill ~/Pictures/wp.jpg

# Environment
exec_always --no-startup-id xrdb -merge ~/.Xresources
exec_always --no-startup-id xset r rate 250 50
