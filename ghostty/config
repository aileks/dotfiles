term = xterm-256color
shell-integration-features = no-cursor
shell-integration = zsh
theme = ashen
font-family = "GoogleSansCode Nerd Font Mono"
font-family-bold = "GoogleSansCode Nerd Font Mono SemiBold"
font-family-italic = "GoogleSansCode Nerd Font Mono Italic"
font-family-bold-italic = "GoogleSansCode Nerd Font Mono SemiBold SemiBoldItalic"
font-size = 20
background-opacity = 0.9
background-blur = true
cursor-style = block
confirm-close-surface = false
# macos-titlebar-style = hidden
keybind = shift+enter=text:\x1b\r
