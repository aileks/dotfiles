[
  {
    "context": "Editor && !VimControl",
    "bindings": {
      "ctrl-shift-k": "editor::CutToEndOfLine",
      "ctrl-up": "editor::MoveToStartOfParagraph",
      "ctrl-down": "editor::MoveToEndOfParagraph",
      "ctrl-j": "editor::JoinLines",
      "alt-k": "editor::SplitSelectionIntoLines"
    }
  }
]
