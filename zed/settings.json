{
  "agent": {
    "always_allow_tool_actions": true,
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gemini-2.5-pro"
    },
    "model_parameters": [],
    "single_file_review": true,
    "version": "2"
  },
  "icon_theme": "Catppuccin Mocha",
  "features": {
    "edit_prediction_provider": "copilot"
  },
  "calls": {
    "mute_on_join": true
  },
  "theme": "Catppuccin Mocha",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "autosave": "on_focus_change",
  "cursor_blink": false,
  "ui_font_size": 16,
  "ui_font_family": "Open Sans",
  "agent_font_size": 18,
  "agent_font_family": "Open Sans",
  "buffer_font_size": 18,
  "buffer_font_family": "BerkeleyMono Nerd Font",
  "buffer_line_height": "standard",
  "terminal": {
    "font_size": 18
  },
  "projects_online_by_default": true,
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "restore_on_startup": "none",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "ensure_final_newline_on_save": true,
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "project_panel": {
    "default_width": 200
  },
  "outline_panel": {
    "default_width": 100,
    "dock": "right"
  },
  "notification_panel": {
    "default_width": 100
  },
  "auto_fold_dirs": true,
  "format_on_save": "on",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "languages": {
    "Elixir": {
      "format_on_save": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"]
        }
      }
    },
    "Ruby": {
      "language_servers": ["solargraph", "rubocop", "tailwindcss-language-server", "!ruby-lsp"]
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "format_on_save": {
        "language_server": {
          "name": "ruff"
        }
      },
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "lsp": {
    "solargraph": {
      "initialization_options": {
        "diagnostics": true,
        "formatting": true
      }
    },
    "rubocop": {
      "initialization_options": {
        "safeAutocorrect": false
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html"
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*['\"]([^'\"]*)['\"]"]
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 88,
          "lint": {
            "extendSelect": ["I", "F", "E", "W", "B", "UP", "C4", "S", "TCH"]
          }
        }
      }
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "strict"
        }
      }
    }
  },
  "diagnostics": {
    "include_warnings": false,
    "inline": {
      "enabled": true,
      "min_column": 40,
      "max_severity": "warning"
    }
  },
  "scrollbar": {
    "show": "never"
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 1000
    }
  },
  "relative_line_numbers": true,
  "vertical_scroll_margin": 8,
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true
  }
}
