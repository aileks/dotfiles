{
  "agent": {
    "model_parameters": [],
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-7-sonnet-thinking-latest"
    },
    "version": "2"
  },
  "edit_predictions": {
    "mode": "eager",
    "enabled_in_text_threads": true
  },
  "icon_theme": "Material Icon Theme",
  "features": {
    "edit_prediction_provider": "zed"
  },
  "calls": {
    "mute_on_join": true
  },
  "theme": "Rosé Pine",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "autosave": "on_focus_change",
  "cursor_blink": false,
  "ui_font_size": 24,
  "ui_font_family": "Rubik",
  "agent_font_size": 24,
  "agent_font_family": "BerkeleyMono Nerd Font",
  "buffer_font_size": 24,
  "buffer_font_family": "BerkeleyMono Nerd Font",
  "buffer_line_height": "standard",
  "terminal": {
    "font_size": 22
  },
  "projects_online_by_default": true,
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "restore_on_startup": "none",
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false
  },
  "ensure_final_newline_on_save": true,
  "tabs": {
    "git_status": true,
    "file_icons": true
  },
  "project_panel": {
    "default_width": 200
  },
  "outline_panel": {
    "default_width": 100,
    "dock": "right"
  },
  "notification_panel": {
    "default_width": 100
  },
  "auto_fold_dirs": true,
  "format_on_save": "on",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "languages": {
    "Elixir": {
      "format_on_save": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"]
        }
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "format_on_save": {
        "language_server": {
          "name": "ruff"
        }
      },
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "scrollbar": {
    "show": "never"
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 1000
    }
  },
  "relative_line_numbers": true,
  "vertical_scroll_margin": 8,
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 88,
          "lint": {
            "extendSelect": ["I"]
          }
        }
      }
    }
  },
  "pyright": {
    "settings": {
      "python.analysis": {
        "diagnosticMode": "workspace",
        "typeCheckingMode": "strict"
      }
    }
  },
  "diagnostics": {
    "include_warnings": false,
    "inline": {
      "enabled": true,
      "min_column": 40,
      "max_severity": "warning"
    }
  }
}
