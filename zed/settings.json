// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "telemetry": { "diagnostics": false, "metrics": false },
  "restore_on_startup": "none",

  "ui_font_family": "Google Sans",
  "ui_font_size": 17,
  "buffer_font_family": "GoogleSansCode Nerd Font Mono",
  "buffer_font_size": 16,
  "buffer_line_height": "comfortable",
  "agent_buffer_font_size": 16,
  "agent_ui_font_size": 18,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ashen"
  },
  "icon_theme": "Colored Zed Icons Theme Dark",

  "tab_bar": {
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true
  },
  "title_bar": { "show_branch_icon": true },
  "toolbar": {
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false
  },
  "minimap": {
    "show": "never",
    "max_width_columns": 100
  },
  "scrollbar": {
    "diagnostics": "warning",
    "axes": { "vertical": false, "horizontal": false }
  },

  "base_keymap": "VSCode",
  "relative_line_numbers": "enabled",
  "autosave": "on_focus_change",
  "auto_indent_on_paste": true,
  "show_whitespaces": "trailing",
  "wrap_guides": [80, 120],
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "tab_size": 2,
  "always_treat_brackets_as_autoclosed": true,
  "colorize_brackets": true,
  "snippet_sort_order": "top",
  "use_smartcase_search": true,
  "search": {
    "center_on_match": true,
    "regex": true
  },
  "diagnostics": {
    "inline": { "enabled": true }
  },
  "inlay_hints": {
    "enabled": false,
    "edit_debounce_ms": 600,
    "show_background": true
  },

  "vim_mode": true,
  "vim": { "use_system_clipboard": "always" },

  "git": {
    "inline_blame": { "delay_ms": 1000 }
  },

  "terminal": {
    "font_family": "GoogleSansCode Nerd Font Mono",
    "font_size": 16.0
  },

  "agent_servers": {
    "claude-acp": { "type": "registry" }
  },

  "prettier": { "allowed": true },

  "languages": {
    "TypeScript": {
      "format_on_save": "on",
      "code_actions_on_format": { "source.fixAll.oxc": true }
    },
    "TSX": {
      "format_on_save": "on",
      "code_actions_on_format": { "source.fixAll.oxc": true }
    },
    "JavaScript": {
      "format_on_save": "on",
      "code_actions_on_format": { "source.fixAll.oxc": true }
    },
    "CSS": {
      "format_on_save": "on",
      "language_servers": ["tailwindcss-language-server"]
    }
  },

  "lsp": {
    "vtsls": {
      "settings": {
        "javascript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true }
          }
        },
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": { "enabled": true },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": { "enabled": true },
            "functionLikeReturnTypes": { "enabled": true },
            "enumMemberValues": { "enabled": true }
          }
        }
      }
    }
  }
}
