{
  "systemCmd": "checkupdates 2>/dev/null",
  "aurCmd": "yay -Qua 2>/dev/null",
  "updateCmd": "kitty -e bash -c 'echo \"Updating System...\";yay; flatpak update; read -n 1 -p \"Press any key to exit...\"'",
  "flatpak": true,
  "noctalia": true,
  "toast": true,
  "desktopTip": true,
  "hideOnEmpty": true,
  "refreshTimer": true,
  "refreshInterval": 120,
  "iconName": "arrow-big-down-lines",
  "useDistroLogo": false,
  "customIconPath": "",
  "boldText": true,
  "enableColorization": false,
  "iconColor": "none",
  "boldVer": true,
  "tooltip": true,
  "closeButton": true,
  "panelTooltip": true,
  "panelContext": true,
  "boldVerPanel": true,
  "boldVerDesktop": true,
  "hoverTip": true
}
