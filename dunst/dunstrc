[global]
font = BerkeleyMono Nerd Font 14
origin = top-right
offset = (5, 0)
height = (80, 400)
frame_width = 2
separator_height = 2
padding = 10
horizontal_padding = 10
separator_color = frame

[urgency_low]
background = "#1d2021"
foreground = "#ebddb2"
frame_color = "#928374"

[urgency_normal]
background = "#1d2021"
foreground = "#ebddb2"
frame_color = "#83a598"

[urgency_critical]
background = "#3c1f1e"
foreground = "#fbf1c7"
frame_color = "#fb4934"
