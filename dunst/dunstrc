[global]
icon_theme="Windows XP"
enable_recursive_icon_lookup = true
separator_color= frame
font = "BerkeleyMono Nerd Font 12"
corner_radius = 0
scale = 1.5
frame_width = 1

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
