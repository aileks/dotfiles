#!/usr/bin/env bash

set -Eeuo pipefail

case "${1:-}" in
  down) direction=- ;;
  up) direction=+ ;;
  *) exit 2 ;;
esac

exec 9> "${XDG_RUNTIME_DIR:-/tmp}/monitor-brightness.lock"
flock --nonblock 9 || exit 0

ddcutil setvcp 10 "$direction" 5 --display 1 --noverify || true
ddcutil setvcp 10 "$direction" 5 --display 2 --mccs=2.2 --noverify || true
