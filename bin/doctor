#!/usr/bin/env bash

set -uo pipefail

failures=0
desktop_active=0
booted_graphics=0
ok_color=""
warn_color=""
out_reset=""
error_color=""
err_reset=""

if [[ ! -v NO_COLOR && -t 1 ]]; then
	ok_color=$'\e[32m'
	warn_color=$'\e[33m'
	out_reset=$'\e[0m'
fi
if [[ ! -v NO_COLOR && -t 2 ]]; then
	error_color=$'\e[31m'
	err_reset=$'\e[0m'
fi

pass() { printf '%s[ok]%s %s\n' "$ok_color" "$out_reset" "$*"; }
warn() { printf '%s[warn]%s %s\n' "$warn_color" "$out_reset" "$*"; }
fail() {
	printf '%s[fail]%s %s\n' "$error_color" "$err_reset" "$*" >&2
	failures=$((failures + 1))
}
error() { printf '%s[error]%s %s\n' "$error_color" "$err_reset" "$*" >&2; }

[[ $# == 0 ]] || {
	error 'doctor takes no arguments'
	exit 2
}

if [[ ${XDG_CURRENT_DESKTOP:-} == *Hyprland* ]] && command -v hyprctl >/dev/null; then
	desktop_active=1
fi
if ((desktop_active)) || systemctl is-active --quiet sddm.service; then
	booted_graphics=1
fi

check_command() {
	if command -v "$1" >/dev/null; then
		pass "$1 installed"
	else
		fail "$1 missing"
	fi
}

check_enabled() {
	if systemctl is-enabled --quiet "$1"; then
		pass "$1 enabled"
	else
		fail "$1 disabled"
	fi
}

check_disabled() {
	if systemctl is-enabled --quiet "$1"; then
		fail "$1 enabled"
	else
		pass "$1 disabled"
	fi
}

check_package() {
	if pacman -Qq "$1" >/dev/null 2>&1; then
		pass "$1 installed"
	else
		fail "$1 missing"
	fi
}

check_limine_snapper_sync() {
	if systemctl is-active --quiet limine-snapper-sync.service; then
		pass 'Limine snapshot watcher active'
	elif [[ -x /usr/lib/snapper/plugins/10-limine-snapper-sync ]]; then
		pass 'Limine Snapper plugin available'
	else
		fail 'Limine snapshot synchronization unavailable'
	fi
}

check_setting() {
	local file="$1" key="$2" expected="$3" label="$4" value
	value=$(awk -F= -v key="$key" '
		$1 == key {
			value = $2
			gsub(/^"|"$/, "", value)
			print value
		}
	' "$file" 2>/dev/null | tail -n 1)
	if [[ $value == "$expected" ]]; then
		pass "$label"
	else
		fail "$label"
	fi
}

check_user_active() {
	if systemctl --user is-active --quiet "$1"; then
		pass "$1 active"
	else
		fail "$1 inactive"
	fi
}

nvidia_drm_active() {
	local card connector driver
	for card in /sys/class/drm/card[0-9]*; do
		[[ -e $card ]] || continue
		driver=$(basename "$(readlink -f "$card/device/driver" 2>/dev/null)")
		[[ $driver == nvidia ]] || continue
		for connector in "$card"-*; do
			[[ -e $connector ]] && return 0
		done
	done
	return 1
}

check_nvidia_modeset() {
	local parameter=/sys/module/nvidia_drm/parameters/modeset
	if [[ -r $parameter ]]; then
		if [[ $(<"$parameter") == Y ]]; then
			pass 'Nvidia DRM modesetting enabled'
		else
			fail 'Nvidia DRM modesetting disabled'
		fi
	elif [[ -e $parameter ]] && nvidia_drm_active; then
		pass 'Nvidia DRM modesetting active'
	elif ((!booted_graphics)); then
		warn 'Nvidia module loads after reboot'
	elif [[ -e $parameter ]]; then
		warn 'Nvidia DRM modesetting value requires root and could not be verified'
	else
		fail 'Nvidia DRM module unavailable'
	fi
}

check_nvidia_fbdev() {
	local parameter=/sys/module/nvidia_drm/parameters/fbdev
	if [[ -r $parameter ]]; then
		if [[ $(<"$parameter") == Y ]]; then
			pass 'Nvidia framebuffer enabled'
		else
			fail 'Nvidia framebuffer disabled'
		fi
	elif [[ -e $parameter ]] && grep -q 'nvidia-drmdrmfb' /proc/fb 2>/dev/null; then
		pass 'Nvidia framebuffer active'
	elif ((!booted_graphics)); then
		warn 'Nvidia framebuffer loads after reboot'
	elif [[ -e $parameter ]]; then
		warn 'Nvidia framebuffer value requires root and could not be verified'
	else
		fail 'Nvidia framebuffer parameter unavailable'
	fi
}

check_snapper() {
	local configs home_fstype package root_fstype
	root_fstype=$(findmnt -no FSTYPE / 2>/dev/null || true)
	home_fstype=$(findmnt -no FSTYPE /home 2>/dev/null || true)
	if [[ $root_fstype == btrfs && $home_fstype == btrfs ]]; then
		pass 'root and home use Btrfs'
	else
		fail 'root or home is not Btrfs'
	fi
	for package in btrfs-progs snapper snap-pac limine-mkinitcpio-hook limine-snapper-sync; do
		check_package "$package"
	done
	configs=$(snapper --csvout --no-headers list-configs 2>/dev/null || true)
	if cut -d, -f1 <<<"$configs" | grep -Fxq root; then
		pass 'root Snapper config present'
	else
		fail 'root Snapper config missing'
	fi
	if cut -d, -f1 <<<"$configs" | grep -Fxq home; then
		pass 'home Snapper config present'
	else
		fail 'home Snapper config missing'
	fi
	check_setting /etc/snapper/configs/root TIMELINE_CREATE no \
		'root timeline snapshots disabled'
	check_setting /etc/snapper/configs/root NUMBER_LIMIT 10 \
		'root snapshot retention is 10'
	check_setting /etc/snapper/configs/home TIMELINE_CREATE no \
		'home hourly snapshots disabled'
	check_setting /etc/snapper/configs/home TIMELINE_LIMIT_WEEKLY 8 \
		'home weekly retention is 8'
	check_setting /etc/default/limine LIMIT_USAGE_PERCENT 85 \
		'Limine snapshot usage limit is 85 percent'
	check_setting /etc/default/limine MAX_SNAPSHOT_ENTRIES auto \
		'Limine snapshot entries auto-prune'
	if grep -Eq '^[[:space:]]*HOOKS=.*[[:space:](]btrfs-overlayfs([[:space:])]|$)' \
		/etc/mkinitcpio.conf 2>/dev/null; then
		pass 'mkinitcpio snapshot overlay enabled'
	else
		fail 'mkinitcpio snapshot overlay missing'
	fi
	check_disabled snapper-timeline.timer
	check_enabled snapper-cleanup.timer
	check_enabled snapper-home-weekly.timer
	check_enabled limine-snapper-sync.service
	check_limine_snapper_sync
	if [[ -f /var/lib/aileks-dotfiles/snapper-v1 ]]; then
		pass 'Snapper setup marker present'
	else
		fail 'Snapper setup marker missing'
	fi
}

check_system() {
	local command file
	for command in Hyprland uwsm sddm nvidia-smi NetworkManager pipewire waybar fuzzel swaync-client swayosd-client hyprlock hypridle hyprpaper nwg-look snapper limine-snapper-info; do
		check_command "$command"
	done
	for file in sddm sddm-autologin sddm-greeter hyprlock; do
		if [[ -r /etc/pam.d/$file ]]; then
			pass "/etc/pam.d/$file present"
		else
			fail "/etc/pam.d/$file missing"
		fi
	done
	if grep -Eq 'include[[:space:]]+system-login' /etc/pam.d/sddm &&
		grep -q 'pam_gnome_keyring[.]so' /etc/pam.d/sddm; then
		pass 'SDDM PAM and keyring integration valid'
	else
		fail 'SDDM PAM integration invalid'
	fi
	if grep -Eq 'include[[:space:]]+system-local-login' /etc/pam.d/sddm-autologin &&
		grep -q 'pam_gnome_keyring[.]so' /etc/pam.d/sddm-autologin; then
		pass 'SDDM autologin PAM integration valid'
	else
		fail 'SDDM autologin PAM integration invalid'
	fi
	if grep -Eq 'auth[[:space:]]+required[[:space:]]+pam_permit[.]so' /etc/pam.d/sddm-greeter; then
		pass 'SDDM greeter PAM integration valid'
	else
		fail 'SDDM greeter PAM integration invalid'
	fi
	if [[ -r /etc/sddm.conf.d/10-autologin.conf ]]; then
		pass 'SDDM autologin configured'
	else
		fail 'SDDM autologin config missing'
	fi
	if [[ -r /usr/share/wayland-sessions/hyprland-uwsm.desktop ]] &&
		grep -Eq '^Exec=uwsm start .*hyprland[.]desktop$' \
			/usr/share/wayland-sessions/hyprland-uwsm.desktop; then
		pass 'UWSM session installed'
	else
		fail 'UWSM session missing'
	fi
	for file in NetworkManager.service avahi-daemon.service bluetooth.service cups.service sddm.service systemd-timesyncd.service; do
		check_enabled "$file"
	done
	check_enabled "hyprlock-suspend@$(id -u).service"
	check_snapper
	check_nvidia_modeset
	check_nvidia_fbdev
	if [[ -r /proc/driver/nvidia/params ]]; then
		if grep -Eq '^(UseKernelSuspendNotifiers|PreserveVideoMemoryAllocations):[[:space:]]+1$' \
			/proc/driver/nvidia/params; then
			pass 'Nvidia suspend memory preservation enabled'
		else
			fail 'Nvidia suspend memory preservation disabled'
		fi
	elif ((!booted_graphics)); then
		warn 'Nvidia suspend parameters load after reboot'
	else
		fail 'Nvidia suspend parameters unavailable'
	fi
}

check_session() {
	local errors monitors main_count restore_lock side_count user_bus_names
	if [[ ${XDG_CURRENT_DESKTOP:-} == *Hyprland* ]]; then
		pass 'Hyprland desktop environment exported'
	else
		fail 'XDG_CURRENT_DESKTOP is not Hyprland'
	fi
	if systemctl --user is-active --quiet graphical-session.target; then
		pass 'graphical-session.target active'
	else
		fail 'graphical-session.target inactive'
	fi
	if systemctl --user cat hyprlock.service >/dev/null 2>&1; then
		pass 'hyprlock.service available'
	else
		fail 'hyprlock.service missing'
	fi
	for unit in waybar.service swaync.service hypridle.service swayosd-server.service \
		cliphist-text.service cliphist-image.service nm-applet.service \
		udiskie.service hyprpaper.service hyprpolkitagent.service \
		pipewire.service pipewire-pulse.service wireplumber.service \
		xdg-desktop-portal.service xdg-desktop-portal-hyprland.service; do
		check_user_active "$unit"
	done
	user_bus_names=$(busctl --user --list 2>/dev/null || true)
	if grep -q '^org[.]blueman[.]Applet[[:space:]]' <<<"$user_bus_names"; then
		pass 'blueman applet active'
	else
		fail 'blueman applet inactive'
	fi
	errors=$(hyprctl configerrors 2>/dev/null || true)
	if [[ -z $errors ]]; then
		pass 'Hyprland config has no errors'
	else
		fail "Hyprland config errors: $errors"
	fi
	restore_lock=$(hyprctl getoption misc:allow_session_lock_restore 2>/dev/null |
		awk '$1 == "bool:" {print $2; exit}')
	if [[ $restore_lock == true ]]; then
		pass 'Hyprland session lock restoration enabled'
	else
		fail 'Hyprland session lock restoration disabled'
	fi
	if monitors=$(hyprctl -j monitors 2>/dev/null); then
		main_count=$(jq '[.[] | select(.width == 2560 and .height == 1440 and .x == 1080 and .y == 0 and .refreshRate >= 199)] | length' <<<"$monitors")
		side_count=$(jq '[.[] | select(.width == 1920 and .height == 1080 and .x == 0 and .y == -240 and .transform == 1 and .refreshRate >= 199)] | length' <<<"$monitors")
		if ((main_count == 1)); then
			pass 'main monitor geometry correct'
		else
			fail 'main monitor geometry incorrect'
		fi
		if ((side_count == 1)); then
			pass 'portrait monitor geometry correct'
		else
			fail 'portrait monitor geometry incorrect'
		fi
	else
		fail 'could not query Hyprland monitors'
	fi
	if wpctl status >/dev/null 2>&1; then
		pass 'PipeWire responds'
	else
		fail 'PipeWire unavailable'
	fi
	if busctl --user --list 2>/dev/null | grep -q org.freedesktop.secrets; then
		pass 'Secret Service available'
	else
		warn 'Secret Service has not been activated; first use will request keyring unlock'
	fi
}

check_system
if ((desktop_active)); then
	check_session
else
	warn 'Hyprland session checks skipped'
fi

((failures == 0))
