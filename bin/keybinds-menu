#!/usr/bin/env bash

set -Eeuo pipefail

printf '%s\n' \
  'Super + Space       Application launcher' \
  'Super + Return      Terminal' \
  'Super + W/E/S/M     Browser / Files / Signal / Fastmail' \
  'Super + I           Desktop settings' \
  "Super + Q/F/'       Close / Fullscreen / Float" \
  'Super + H/J/K/L     Focus window' \
  'Super + Shift + H/J/K/L  Move window' \
  'Super + R           Resize mode' \
  'Super + 1..8        Select workspace' \
  'Super + Shift + 1..8  Move to workspace' \
  'Super + ,/.         Select monitor' \
  'Super + Shift + ,/. Move to monitor' \
  'Super + V/N         Clipboard / Notifications' \
  'Super + /           Keybind help' \
  'Super + Escape      Lock' \
  'Super + Shift + E   Power menu' \
  'Print / Shift + Print  Region / Full screenshot' |
  fuzzel --dmenu --prompt='Keybinds > ' --width=72 --lines=18 >/dev/null
