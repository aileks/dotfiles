#!/usr/bin/env bash

set -Eeuo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
monitors_destination="$state_dir/monitors.lua"
workspaces_destination="$state_dir/workspaces.lua"
mkdir -p "$state_dir"

[[ -f $monitors_destination && -f $workspaces_destination ]] && exit 0

for _ in {1..30}; do
  if monitors=$(hyprctl -j monitors all 2>/dev/null); then
    break
  fi
  sleep 1
done

[[ ${monitors:-} == \[* ]] || exit 1

main=$(jq -r '
  [.[] | select(any(.availableModes[]?; startswith("2560x1440@")))]
  | first | .name // empty
' <<<"$monitors")

side=$(jq -r --arg main "$main" '
  [.[] | select(.name != $main) | select(any(.availableModes[]?; startswith("1920x1080@")))]
  | first | .name // empty
' <<<"$monitors")

best_mode() {
  local output="$1" resolution="$2"
  jq -r --arg output "$output" --arg resolution "$resolution" '
    .[] | select(.name == $output)
    | [.availableModes[]? | select(startswith($resolution + "@"))
       | { mode: sub("Hz$"; ""), delta: ((split("@")[1] | sub("Hz$"; "") | tonumber) - 200 | fabs) }]
    | sort_by(.delta) | first | .mode // "highrr"
  ' <<<"$monitors"
}

lua_string() {
  jq -Rn --arg value "$1" '$value'
}

monitors_tmp="$state_dir/monitors.lua.new"
{
  printf '%s\n' '-- Generated by configure-monitors. Do not edit.'
  if [[ -n $main ]]; then
    main_mode=$(best_mode "$main" 2560x1440)
    printf 'hl.monitor({ output = %s, mode = %s, position = "1080x0", scale = 1 })\n' \
      "$(lua_string "$main")" "$(lua_string "$main_mode")"
  fi
  if [[ -n $side ]]; then
    side_mode=$(best_mode "$side" 1920x1080)
    printf 'hl.monitor({ output = %s, mode = %s, position = "0x-240", scale = 1, transform = 1 })\n' \
      "$(lua_string "$side")" "$(lua_string "$side_mode")"
  fi
} >"$monitors_tmp"

workspaces_tmp="$state_dir/workspaces.lua.new"
{
  printf '%s\n' '-- Generated by configure-monitors. Do not edit.'
  if [[ -n $main ]]; then
    for workspace in {1..7}; do
      printf 'hl.workspace_rule({ workspace = "%s", monitor = %s, persistent = true, default = %s })\n' \
        "$workspace" "$(lua_string "$main")" "$([[ $workspace == 1 ]] && printf true || printf false)"
    done
  fi
  if [[ -n $side ]]; then
    printf 'hl.workspace_rule({ workspace = "8", monitor = %s, persistent = true, default = true })\n' \
      "$(lua_string "$side")"
  fi
} >"$workspaces_tmp"

install -m 0644 "$monitors_tmp" "$monitors_destination"
install -m 0644 "$workspaces_tmp" "$workspaces_destination"
hyprctl reload
