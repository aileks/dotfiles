#!/usr/bin/env bash

menu() {
  echo -e "$2" | walker --dmenu --theme dmenu_250 -p "$1‚Ä¶" $3
}

case $(menu "System" "ÔÄ£  Lock\nůį§Ą  Suspend\nÔćô  Relaunch\nůįúČ  Restart\nůįź•  Shutdown") in
*Lock*) hyprlock ;;
*Suspend*) systemctl suspend ;;
*Relaunch*) uwsm stop ;;
*Restart*) systemctl reboot ;;
*Shutdown*) systemctl poweroff ;;
*) exit 0 ;;
esac
