#!/usr/bin/env bash

set -Eeuo pipefail

devices=""
for _ in {1..20}; do
  if devices=$(hyprctl -j devices 2>/dev/null); then
    break
  fi
  sleep 0.25
done

[[ -n $devices ]] || exit 1
if jq -e 'any(.keyboards[]; .main and .capsLock)' <<<"$devices" >/dev/null; then
  exit 0
fi

# Physical Right Ctrl is Caps Lock in the custom keymap.
ydotool key 97:1 97:0
sleep 0.1
hyprctl -j devices |
  jq -e 'any(.keyboards[]; .main and .capsLock)' >/dev/null
