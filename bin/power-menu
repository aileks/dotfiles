#!/usr/bin/env bash

set -Eeuo pipefail

selection=$(printf '%s\n' Lock Logout Suspend Reboot Shutdown |
  fuzzel --dmenu --minimal-lines --prompt='Power > ')
[[ -n $selection ]] || exit 0

case "$selection" in
  Lock)
    exec loginctl lock-session
    ;;
  Logout)
    command=(uwsm stop)
    ;;
  Suspend)
    command=(systemctl suspend)
    ;;
  Reboot)
    command=(systemctl reboot)
    ;;
  Shutdown)
    command=(systemctl poweroff)
    ;;
  *) exit 0 ;;
esac

confirmation=$(printf '%s\n' No Yes | fuzzel --dmenu --minimal-lines --prompt="$selection? ")
[[ $confirmation == Yes ]] || exit 0
exec "${command[@]}"
