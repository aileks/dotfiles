// =============================================================================
// General
// =============================================================================

prefer-no-csd

environment {
    XDG_CURRENT_DESKTOP "niri"
    GTK_CSD "0"
    TERMINAL "kitty"
    XCURSOR_THEME "Adwaita"
    XCURSOR_SIZE "24"
}

cursor {
    hide-after-inactive-ms 2000
    xcursor-theme "Adwaita"
    xcursor-size 24
}

input {
    mod-key "Super"

    keyboard {
        repeat-delay 250
        repeat-rate 50
        numlock
    }

    touchpad {
        tap
        natural-scroll
        accel-profile "flat"
        accel-speed 0.0
    }

    mouse {
        accel-profile "flat"
        accel-speed 0.0
    }

    focus-follows-mouse
}

// =============================================================================
// Outputs
// =============================================================================

output "DP-2" {
    mode "1920x1080@200"
    transform "90"
    position x=0 y=0
}

output "DP-3" {
    mode "1920x1080@200"
    position x=1080 y=280
}

// =============================================================================
// Layout
// =============================================================================

layout {
    gaps 6
    struts {
      top 0
      left -3
      right -3
      bottom -3
    }

    default-column-width { proportion 0.5; }

    focus-ring { off; }

    border {
        width 1.5
        active-color "#c4693d"
        inactive-color "#535353"
        urgent-color "#df6464"
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=2
        draw-behind-window true
        color "#12121299"
        inactive-color "#12121280"
    }

    insert-hint {
        on
        color "#e5a72a66"
    }
}

hotkey-overlay {
    skip-at-startup
}

screenshot-path "~/Pictures/screenshots/screenshot-%Y%m%d-%H%M%S.png"

// =============================================================================
// Effects
// =============================================================================

blur {
    passes 3
    offset 3.0
    noise 0.03
    saturation 1.0
}

animations {
    workspace-switch {
        spring damping-ratio=1.0 stiffness=900 epsilon=0.0001
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=900 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=900 epsilon=0.0001
    }

    window-resize {
        spring damping-ratio=1.0 stiffness=900 epsilon=0.0001
    }

    window-open {
        duration-ms 140
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 140
        curve "ease-out-quad"
    }
}

// =============================================================================
// Window rules
// =============================================================================

window-rule {
  background-effect {
    blur true
  }
}

window-rule {
    match app-id=r#"^(imv|qalculate-gtk|XIVLauncher)$"#
    open-floating true
}

window-rule {
    match app-id=r#".*portal.*"#
    open-floating true
}

window-rule {
    match app-id="thunar" title=r#"Rename"#
    open-floating true
}

window-rule {
    match title=r#"About|Authentication|Confirm|Configuration|Dialog|Error|Open File|Options|Preferences|Properties|Save As|Save File|Select File|Select Folder|Settings|Warning"#
    open-floating true
}

window-rule {
    match app-id="Fastmail"
    open-on-workspace "7"
}

window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}

// =============================================================================
// Layer rules
// =============================================================================

layer-rule {
    match namespace="^noctalia-notification"
    shadow { off; }
}

layer-rule {
    match namespace="^noctalia-launcher"
    geometry-corner-radius 12
    shadow {
        on
        softness 30
        spread 6
        offset x=0 y=8
        color "#00000080"
    }
}

layer-rule {
  match namespace="^noctalia-(background|launcher-overlay|dock)-.*$"
  background-effect {
    blur true
  }
}

// =============================================================================
// Workspaces
// =============================================================================

workspace "1" { open-on-output "DP-3"; }
workspace "2" { open-on-output "DP-3"; }
workspace "3" { open-on-output "DP-3"; }
workspace "4" { open-on-output "DP-3"; }
workspace "5" { open-on-output "DP-3"; }
workspace "6" { open-on-output "DP-3"; }
workspace "7" { open-on-output "DP-3"; }

// =============================================================================
// Binds
// =============================================================================

binds {
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Q       { close-window; }
    Mod+Shift+Q { quit; }

    // Apps
    Mod+Return     { spawn "kitty"; }
    Mod+D          { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+Shift+E    { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "emoji"; }
    Mod+E          { spawn "thunar"; }
    Mod+W          { spawn "zen-browser"; }
    Mod+S          { spawn "signal-desktop"; }
    Mod+M          { spawn "fastmail"; }
    Mod+V          { spawn "zeditor"; }
    Mod+Shift+X    { spawn "lock"; }
    Mod+Shift+P    { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "sessionMenu" "toggle"; }

    // Focus
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }

    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }

    // Layout
    Mod+R           { switch-preset-column-width; }
    Mod+Shift+R     { switch-preset-window-height; }
    Mod+Ctrl+R      { reset-window-height; }
    Mod+Shift+Return { maximize-column; }
    Mod+F           { maximize-column; }
    Mod+Shift+F     { fullscreen-window; }
    Mod+Space       { toggle-window-floating; }
    Mod+Shift+V     { toggle-overview; }

    // Monitors
    Mod+Comma       { focus-monitor-left; }
    Mod+Period      { focus-monitor-right; }
    Mod+Shift+Comma  { move-column-to-monitor-left; }
    Mod+Shift+Period { move-column-to-monitor-right; }
    Mod+Ctrl+Comma   { consume-or-expel-window-left; }
    Mod+Ctrl+Period  { consume-or-expel-window-right; }

    // Workspaces
    Mod+1 { focus-workspace "1"; }
    Mod+2 { focus-workspace "2"; }
    Mod+3 { focus-workspace "3"; }
    Mod+4 { focus-workspace "4"; }
    Mod+5 { focus-workspace "5"; }
    Mod+6 { focus-workspace "6"; }
    Mod+7 { focus-workspace "7"; }

    Mod+Shift+1 { move-column-to-workspace "1"; }
    Mod+Shift+2 { move-column-to-workspace "2"; }
    Mod+Shift+3 { move-column-to-workspace "3"; }
    Mod+Shift+4 { move-column-to-workspace "4"; }
    Mod+Shift+5 { move-column-to-workspace "5"; }
    Mod+Shift+6 { move-column-to-workspace "6"; }
    Mod+Shift+7 { move-column-to-workspace "7"; }

    // Screenshots
    Print       { screenshot; }
    Shift+Print { screenshot-window; }
    Mod+Print   { screenshot-screen; }
    Mod+Shift+S { spawn-sh "grim -g \"$(slurp)\" - | satty --filename - --output-filename ~/Pictures/screenshots/annotated-$(date +%Y%m%d-%H%M%S).png"; }

    // Screen recording
    Mod+Alt+R   { spawn "screenrecord" "area"; }
    Mod+Alt+W   { spawn "screenrecord" "window"; }
    Mod+Alt+F   { spawn "screenrecord" "fullscreen"; }

    // Replay buffer
    Mod+Alt+B   { spawn "screenrecord" "replay"; }
    Mod+Alt+S   { spawn "screenrecord" "save-replay"; }

    // Color picker
    Mod+Shift+C { spawn "pick-color"; }

    // Media keys
    XF86AudioRaiseVolume allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "increase"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "decrease"; }
    XF86AudioMute        allow-when-locked=true { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }
    XF86AudioMedia       allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPlay        allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPrev        allow-when-locked=true { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true { spawn-sh "playerctl next"; }

    // Brightness
    XF86MonBrightnessUp   { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "increase"; }
    XF86MonBrightnessDown { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "brightness" "decrease"; }
}

// =============================================================================
// Startup
// =============================================================================

spawn-at-startup "qs" "-c" "noctalia-shell"
spawn-at-startup "solaar" "-w" "hide"

include "./noctalia.kdl"

