#!/bin/bash

set -uo pipefail

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:$PATH"

MODE="${1:-area}"
RECORDING_DIR="$HOME/Videos/recordings"
PIDFILE="/tmp/screenrecord.pid"
REPLAY_PIDFILE="/tmp/screenrecord-replay.pid"
FPS="${SCREENRECORD_FPS:-60}"
QUALITY="${SCREENRECORD_QUALITY:-very_high}"
CODEC="${SCREENRECORD_CODEC:-h264}"
AUDIO_CODEC="${SCREENRECORD_AUDIO_CODEC:-aac}"
REPLAY_SECONDS="${SCREENRECORD_REPLAY_SECONDS:-30}"
AUDIO_SOURCE="${SCREENRECORD_AUDIO_SOURCE:-default_output}"

notify() {
  local title="$1"
  local message="$2"
  local urgency="${3:-normal}"

  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a screenrecord -u "$urgency" "$title" "$message"
  else
    printf '%s\n' "$title: $message" >&2
  fi
}

require_bin() {
  if ! command -v "$1" >/dev/null 2>&1; then
    notify "Recording error" "Missing dependency: $1" "critical"
    exit 1
  fi
}

require_bin gpu-screen-recorder

new_filename() {
  printf 'recording-%s.mp4' "$(date +%Y%m%d-%H%M%S)"
}

stop_active_recording() {
  if [[ -f $PIDFILE ]]; then
    local pid
    pid=$(cat "$PIDFILE")
    if kill -0 "$pid" 2>/dev/null; then
      kill -SIGINT "$pid"
      rm -f "$PIDFILE"
      notify "Recording stopped" "Saved to $RECORDING_DIR"
      return 0
    fi
    rm -f "$PIDFILE"
  fi
  return 1
}

focused_output() {
  require_bin niri
  require_bin jq
  niri msg --json focused-output 2>/dev/null \
    | jq -r '(.Ok // .) | (.name // .Name // empty)'
}

start_recording() {
  local target="$1"
  mkdir -p "$RECORDING_DIR"
  local outfile="$RECORDING_DIR/$(new_filename)"

  gpu-screen-recorder \
    -w "$target" \
    -c mp4 \
    -k "$CODEC" \
    -ac "$AUDIO_CODEC" \
    -a "$AUDIO_SOURCE" \
    -f "$FPS" \
    -q "$QUALITY" \
    -o "$outfile" \
    >/dev/null 2>&1 &

  echo $! >"$PIDFILE"
  notify "Recording started" "Mode: $MODE → $(basename "$outfile")"
}

start_replay() {
  if [[ -f $REPLAY_PIDFILE ]] && kill -0 "$(cat "$REPLAY_PIDFILE")" 2>/dev/null; then
    notify "Replay buffer" "Already running (pid $(cat "$REPLAY_PIDFILE"))"
    return 0
  fi

  mkdir -p "$RECORDING_DIR"
  local target
  target=$(focused_output)
  [[ -n $target ]] || target="screen"

  gpu-screen-recorder \
    -w "$target" \
    -c mp4 \
    -k "$CODEC" \
    -ac "$AUDIO_CODEC" \
    -a "$AUDIO_SOURCE" \
    -f "$FPS" \
    -q "$QUALITY" \
    -r "$REPLAY_SECONDS" \
    -o "$RECORDING_DIR" \
    >/dev/null 2>&1 &

  echo $! >"$REPLAY_PIDFILE"
  notify "Replay buffer started" "Last ${REPLAY_SECONDS}s on demand"
}

save_replay() {
  if [[ ! -f $REPLAY_PIDFILE ]]; then
    notify "Replay buffer" "Not running" "critical"
    exit 1
  fi
  local pid
  pid=$(cat "$REPLAY_PIDFILE")
  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$REPLAY_PIDFILE"
    notify "Replay buffer" "Process gone; restart with screenrecord replay" "critical"
    exit 1
  fi
  if kill -SIGUSR1 "$pid"; then
    notify "Replay saved" "Last ${REPLAY_SECONDS}s flushed to $RECORDING_DIR"
  else
    notify "Replay save failed" "Could not signal pid $pid" "critical"
    exit 1
  fi
}

stop_replay() {
  if [[ ! -f $REPLAY_PIDFILE ]]; then
    notify "Replay buffer" "Not running"
    return 0
  fi
  local pid
  pid=$(cat "$REPLAY_PIDFILE")
  if kill -0 "$pid" 2>/dev/null; then
    kill -SIGINT "$pid"
  fi
  rm -f "$REPLAY_PIDFILE"
  notify "Replay buffer stopped" ""
}

case "$MODE" in
  area)
    stop_active_recording && exit 0
    start_recording region
    ;;
  window)
    stop_active_recording && exit 0
    start_recording portal
    ;;
  fullscreen)
    stop_active_recording && exit 0
    target=$(focused_output)
    [[ -n $target ]] || target="screen"
    start_recording "$target"
    ;;
  toggle)
    stop_active_recording && exit 0
    start_recording region
    ;;
  replay)
    start_replay
    ;;
  save-replay)
    save_replay
    ;;
  stop-replay)
    stop_replay
    ;;
  *)
    cat >&2 <<EOF
Usage: screenrecord <mode>

Recording modes (toggle off by re-running):
  area         Drag a region with slurp
  window       Pick a window via xdg-desktop-portal
  fullscreen   Currently focused output
  toggle       Alias for area

Replay buffer (Shadowplay-style):
  replay       Start the replay buffer (last ${REPLAY_SECONDS}s)
  save-replay  Flush the buffered seconds to disk
  stop-replay  Stop the replay buffer

Env overrides: SCREENRECORD_FPS, SCREENRECORD_QUALITY, SCREENRECORD_CODEC,
SCREENRECORD_AUDIO_CODEC, SCREENRECORD_AUDIO_SOURCE, SCREENRECORD_REPLAY_SECONDS
EOF
    exit 1
    ;;
esac
