{
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  "workbench.enableExperiments": false,
  "chat.fontSize": 16,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "window.restoreWindows": "none",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.gpuAcceleration": "on",
  "python-envs.defaultEnvManager": "ms-python.python:conda",
  "python-envs.defaultPackageManager": "ms-python.python:conda",
  "security.allowedUNCHosts": ["wsl.localhost"],
  "github.copilot.nextEditSuggestions.enabled": true,
  "editor.formatOnSave": true,
  "files.autoSave": "onFocusChange",
  "editor.fontFamily": "BerkeleyMono Nerd Font",
  "editor.wordWrap": "on",
  "editor.formatOnPaste": true,
  "editor.mouseWheelZoom": true,
  "editor.autoIndentOnPaste": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.minimap.enabled": false,
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "json.format.keepLines": true,
  "editor.fontLigatures": true,
  "editor.guides.bracketPairs": true,
  "window.zoomLevel": -0.5,
  "editor.wordWrapColumn": 100,
  "editor.rulers": [120],
  "python.analysis.typeCheckingMode": "strict",
  "[sql]": {
    "editor.formatOnSave": false
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cSpell.userWords": ["explainability", "Matplotlib", "Plotly", "tidyverse"],
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "chat.editing.confirmEditRequestRemoval": false,
  "git.confirmSync": false,
  "editor.minimap.maxColumn": 100,
  "editor.scrollbar.horizontal": "visible",
  "prettier.experimentalTernaries": true,
  "prettier.printWidth": 100,

  "vim.leader": " ",
  "vim.useSystemClipboard": true,
  "vim.highlightedyank.enable": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "f"],
      "commands": "workbench.action.quickOpen"
    },
    {
      "before": ["<leader>", "p"],
      "commands": "workbench.action.toggleSidebarVisibility"
    },
    {
      "before": ["<leader>", "e"],
      "commands": "workbench.action.toggleSidebarVisibility"
    },
    {
      "before": ["<leader>", "t"],
      "commands": "workbench.action.toggleTerminal"
    },
    {
      "before": ["<leader>", "/"],
      "commands": "workbench.action.findInFiles"
    },
    {
      "before": ["<leader>", "o"],
      "commands": "workbench.view.outline"
    },
    {
      "before": ["<leader>", "s"],
      "commands": "workbench.action.gotoSymbol"
    },
    {
      "before": ["<leader>", "c"],
      "commands": "workbench.action.showCommands"
    },
    {
      "before": ["<leader>", "d"],
      "commands": "workbench.actions.view.problems"
    },
    {
      "before": ["<leader>", "r"],
      "commands": "editor.action.rename"
    },
    {
      "before": ["<leader>", "b"],
      "commands": "gitlens.toggleFileBlame"
    },
    {
      "before": ["<leader>", "g", "a"],
      "commands": "git.stageAll"
    },
    {
      "before": ["<leader>", "g", "c"],
      "commands": "git.commit"
    },
    {
      "before": ["<leader>", "g", "p"],
      "commands": "git.push"
    },
    {
      "before": ["<leader>", "g", "l"],
      "commands": "git.pull"
    },
    {
      "before": ["<leader>", "g", "d"],
      "commands": "workbench.action.files.openChanges"
    },
    {
      "before": ["<leader>", "g", "b"],
      "commands": "git.checkout"
    },
    {
      "before": ["<leader>", "g", "t"],
      "commands": "git.stash"
    },
    {
      "before": ["<leader>", "g", "T"],
      "commands": "git.stashPop"
    },
    {
      "before": ["Y"],
      "after": ["y", "$"]
    },
    {
      "before": ["Z", "Z"],
      "commands": "workbench.action.save"
    },
    {
      "before": ["Z", "Q"],
      "commands": "workbench.action.closeActiveEditor"
    },
    {
      "before": ["<C-d>"],
      "after": ["<C-d>", "z", "z"]
    },
    {
      "before": ["<C-u>"],
      "after": ["<C-u>", "z", "z"]
    },
    {
      "before": ["g", "y", "y"],
      "commands": "editor.action.copyLinesDownAction"
    },
    {
      "before": ["g", "*"],
      "commands": "editor.action.addSelectionToNextFindMatch"
    },
    {
      "before": ["g", "#"],
      "commands": "editor.action.addSelectionToPreviousFindMatch"
    },
    {
      "before": ["L"],
      "commands": "workbench.action.nextEditor"
    },
    {
      "before": ["H"],
      "commands": "workbench.action.previousEditor"
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["g", "c"],
      "commands": "editor.action.commentLine"
    },
    {
      "before": ["g", "A"],
      "commands": "editor.action.insertCursorAtEndOfEachLineSelected"
    },
    {
      "before": [">"],
      "after": [">", "g", "v"]
    },
    {
      "before": ["<"],
      "after": ["<", "g", "v"]
    }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": ["j", "k"],
      "after": ["Esc"]
    },
    {
      "before": ["k", "j"],
      "after": ["Esc"]
    }
  ],
  "settingsSync.ignoredExtensions": ["jonathanharty.gruvbox-material-icon-theme"],
  "workbench.colorTheme": "Min Dark",
  "telemetry.telemetryLevel": "off",
  "editor.fontSize": 16,
  "debug.console.fontSize": 16,
  "editor.minimap.sectionHeaderFontSize": 12,
  "terminal.integrated.fontSize": 16,
  "chat.editor.fontSize": 18,
  "markdown.preview.fontSize": 16
}
