{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 8,
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-center": [],
  "modules-right": ["cpu", "memory", "network", "pulseaudio", "clock", "tray"],
  "niri/workspaces": {
    "format": "{index}"
  },
  "niri/window": {
    "max-length": 80
  },
  "cpu": {
    "interval": 2,
    "format": "َ°»  {usage}%",
    "states": {
      "warning": 50,
      "critical": 80
    },
    "on-click": "wezterm start --class btop-floating -- btop"
  },
  "memory": {
    "interval": 5,
    "format": "َ°چ› {percentage}%",
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
    "states": {
      "warning": 50,
      "critical": 80
    },
    "on-click": "wezterm start --class btop-floating -- btop"
  },
  "network": {
    "interval": 5,
    "format-wifi": "َ°–© {signalStrength}%",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-linked": "َ°ˆپ {ifname} (no IP)",
    "format-disconnected": "َ°¤® Offline",
    "format-disabled": "َ°¤® Off",
    "tooltip-format-wifi": "{essid}\n{ipaddr}/{cidr}\n{signaldBm} dBm ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}\n{gwaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "wezterm start --class network-floating -- nmtui",
    "on-click-right": "sh -c 'nmcli radio wifi | grep -q enabled && nmcli radio wifi off || nmcli radio wifi on'"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": {
      "headphones": "َ°‹‹",
      "headset": "َ°‹ژ",
      "hands-free": "َ°‹ژ",
      "portable": "",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "scroll-step": 5,
    "on-click": "pamixer -t",
    "on-click-right": "wezterm start --class volume-floating -- wiremix"
  },
  "clock": {
    "interval": 60,
    "format": "َ°ƒ° {:%H:%M}",
    "format-alt": "َ°ƒ° {:%a %b %d}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months":   "<span color='#e5a72a'><b>{}</b></span>",
        "days":     "<span color='#d5d5d5'>{}</span>",
        "weeks":    "<span color='#a7a7a7'><b>W{}</b></span>",
        "weekdays": "<span color='#c4693d'><b>{}</b></span>",
        "today":    "<span color='#b14242'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "tray": {
    "icon-size": 18,
    "spacing": 6
  }
}
