{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "margin-top": 3,
    "margin-left": 3,
    "margin-right": 3,

    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["pulseaudio", "cpu", "memory", "temperature", "clock", "custom/notification", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "≤░Ψθ",
            "2": "≤░φ╣",
            "3": "ΌηΧ",
            "4": "≤░βρ",
            "5": "Όσ║",
            "6": "ΎΑΥ",
            "7": "Όυε",
            "urgent": "≤░Αρ",
            "focused": "≤░χψ",
        }
    },

    "sway/mode": {
        "format": "<span style=\"italic\">≤░Κα {}</span>"
    },

    "sway/window": {
        "max-length": 50,
        "format": "≤▒Γυ {title}"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "≤░ΖΡ {:%a, %d %b %H:%M}"
    },

    "cpu": {
        "format": "≤░αγ {usage}%",
        "tooltip": true
    },

    "memory": {
        "format": "≤░Ξδ {}%"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["≤▒ΔΔ", "≤░ΦΠ", "≤▒ΔΓ"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "≤░Γ░ {icon} {volume}%",
        "format-bluetooth-muted": "≤░Γ▓ {icon}",
        "format-muted": "≤░ζθ",
        "format-source": "≤░Ξυ {volume}%",
        "format-source-muted": "≤░Ξφ",
        "format-icons": {
            "headphone": "≤░ΜΜ",
            "hands-free": "≤░ΜΟ",
            "headset": "≤░ΜΟ",
            "phone": "≤░Π▓",
            "portable": "≤░Εζ",
            "car": "≤░ΕΜ",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "on-click": "pavucontrol"
    },

    "custom/notification": {
        "tooltip": false,
        "format": "{} {icon}",
        "format-icons": {
          "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "none": "ΎΓλ",
          "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "dnd-none": "ΎΘ╖",
          "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "inhibited-none": "ΎΓλ",
          "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
          "dnd-inhibited-none": "ΎΘ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
}
